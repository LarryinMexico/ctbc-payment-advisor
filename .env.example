# ── Groq API ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here   # 至 https://console.groq.com 免費取得

# ── Agent 設定 ────────────────────────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile    # 主要模型（支援 tool calling）
# GROQ_MODEL=llama-3.1-8b-instant    # 速度優先替代方案

# ── Scraper 設定 ──────────────────────────────────────────────────────────────
SCRAPER_HEADLESS=true        # true = no browser window; false = visible browser (debug用)
SCRAPER_DELAY_MIN=1.0        # 每次請求前最小延遲秒數
SCRAPER_DELAY_MAX=3.0        # 每次請求前最大延遲秒數
SCRAPER_TIMEOUT=30000        # 頁面等待 timeout (ms)
